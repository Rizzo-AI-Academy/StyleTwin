OPENAI_API_KEY=sk-...
OPENAI_IMAGE_MODEL=gpt-image-2-2026-04-21
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MAX_UPLOAD_MB=10

# PostgreSQL connection string (e.g. Railway, Supabase, local)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Clerk — Dashboard → API Keys + JWT Templates
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-instance.clerk.accounts.dev
CLERK_SECRET_KEY=sk_test_...

# Set to true ONLY for local dev without Clerk; bypasses JWT verification.
AUTH_DISABLED=false

# Persist generated images (base64) in the DB. Set false to keep rows lighter.
STORE_IMAGES_IN_DB=true
