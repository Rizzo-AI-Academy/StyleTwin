VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Backend base URL — leave empty for production on Railway: the Caddy in front
# of the frontend reverse-proxies /api/* to the backend via the private network
# (see frontend/Caddyfile and the BACKEND_URL env var on the frontend service).
#
# Set this only if you want the browser to talk to the backend directly
# (e.g. backend on a different host without a co-located reverse proxy).
VITE_API_BASE_URL=
